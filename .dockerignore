.dockerignore

# Not needed as we are bundling the whole app
node_modules
# Log files
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
.next
.git

config/*
logs/*
auth/*
storage/*

# Staging verifies installer and updater security from the built image. Keep
# these as the final rules so a broader shell-script pattern cannot hide them.
!install.sh
!update.sh
