# Copy this file to .env and replace both blank password values.
# The Compose file refuses to start when either required password is blank.
ADMIN_PASSWORD=
DB_PASSWORD=

# Change to true only when the application is served through HTTPS.
SESSION_COOKIE_SECURE=false

TZ=America/Los_Angeles
APP_PORT=3000
DB_PORT=5432

# Only used with docker-compose.without-database.yml:
# DB_HOST=database-host.example:5432
# DB_NAME=postgres
# DB_USER=postgres
